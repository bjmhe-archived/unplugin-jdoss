{
  "name": "unplugin-jdoss",
  "version": "2.0.5",
  "description": "A build plugin based on unplugin that automatically uploads files to JD OSS after build completion.",
  "keywords": [
    "esbuild",
    "farm",
    "rolldown",
    "rollup",
    "rspack",
    "unplugin",
    "vite",
    "webpack"
  ],
  "homepage": "https://github.com/bjmhe/unplugin-jdoss#readme",
  "bugs": {
    "url": "https://github.com/bjmhe/unplugin-jdoss/issues"
  },
  "license": "MIT",
  "author": "Benjamin He <hi@bjmhe.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjmhe/unplugin-jdoss.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "./*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./esbuild": "./dist/esbuild.mjs",
    "./farm": "./dist/farm.mjs",
    "./rolldown": "./dist/rolldown.mjs",
    "./rollup": "./dist/rollup.mjs",
    "./rspack": "./dist/rspack.mjs",
    "./vite": "./dist/vite.mjs",
    "./webpack": "./dist/webpack.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "release": "bumpp",
    "prerelease": "vp run build"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@bjmhe/automd": "^0.0.7",
    "@bjmhe/bjmhe": "^1.0.2",
    "@bjmhe/viteplus-preset": "^2.0.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260601.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bumpp": "^11.1.0",
    "publint": "^0.3.21",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vite-plus": "^0.1.24"
  },
  "peerDependencies": {
    "@jd/upload-oss-tools": "1.1.28"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@10.33.4"
}
